{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "铃兰之剑maa",
    "description": "桌面版铃兰之剑自动化脚本，包含进入游戏、处理公告、好友领取等功能。",
    "contact": "无",
    "license": "MIT",
    "welcome": "首次使用请确保游戏窗口已打开，并配置好窗口匹配规则",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/fzlxs/-maa",
    "version": "1.0.3",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "window_regex": "铃兰之剑", // 替换为你的游戏窗口标题（支持正则）
                "class_regex": "UnityWndClass", // 替换为窗口类名（通常游戏是 UnityWndClass）
                // 控制方式可根据需要调整，以下为常用组合
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "FramePool", // 截图方式
                "mouse": "Seize", // 鼠标控制方式
                "keyboard": "Seize" // 键盘控制方式
            },
            "display_short_side": 720 // 截图缩放尺寸，保持 720p 即可
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ] // 或者直接 "resource" 也可
        }
    ],
    // 可选的 agent 示例
    // "agent": {
    //     "child_exec": "python",
    //     "child_args": [
    //         "./agent/main.py"
    //     ]
    // },
    "task": [
        {
            "name": "启动游戏",
            "entry": "启动游戏",
            "description": "关闭公告、进入游戏、关闭签到",
            "default_check": true
        },
        {
            "name": "仅好友功能",
            "entry": "好友界面",
            "description": "单独执行好友领取和赠送功能（需已在游戏主界面）。",
            "default_check": false
        },
        {
            "name": "仅远航功能",
            "entry": "点击文字远航",
            "description": "单独执行远航功能（需已在游戏主界面）。",
            "default_check": false
        },
        {
            "name": "仅竞技场（3次）",
            "entry": "竞技场",
            "description": "单独执行竞技场3次（需已在游戏主界面）。",
            "default_check": false
        },
        {
            "name": "领取任务",
            "entry": "领取任务",
            "description": "领取每日任务（需已在游戏主界面）。",
            "default_check": false
            
        },
        {
            "name": "仅神兵试炼",
            "entry": "神兵试炼_开始",
            "description": "单独执行神兵试炼代行。",
            "default_check": false
        },
        {
            "name": "仅记忆寻回",
            "entry": "记忆寻回_开始",
            "description": "单独执行记忆寻回战斗。",
            "default_check": false
        },
        {
            "name": "仅实战训练",
            "entry": "实战训练_开始",
            "description": "单独执行实战训练代行。",
            "default_check": false
        },
        {
            "name": "仅进阶试炼",
            "entry": "进阶试炼_开始",
            "description": "单独执行进阶试炼代行。",
            "default_check": false
        },
        {
            "name": "仅星辰试炼",
            "entry": "星辰试炼_开始",
            "description": "单独执行星辰试炼代行。",
            "default_check": false
        },
        {
            "name": "仅光辉锻铸",
            "entry": "光辉锻铸_开始",
            "description": "单独执行光辉锻铸代行。",
            "default_check": false
        },
        {
            "name": "仅开拓征程",
            "entry": "开拓征程_开始",
            "description": "单独执行开拓征程任务。",
            "default_check": false
        },
        {
            "name": "仅征服之塔（8-1至8-5）",
